# Сборочные артефакты единого бинаря.
/bin/
backend/bin/

# Локальные конфиги и базы.
backend/config.yaml
*.db
*.db-shm
*.db-wal

# Зависимости и сборки web.
web/node_modules/
web/dist/

# Артефакты инструментов в корне репозитория (не часть проекта): node_modules —
# остатки npx-запусков, data — служебное хранилище memoir, .playwright-mcp —
# скриншоты браузерных проверок.
/node_modules/
/data/
.playwright-mcp/

# Встроенный фронтенд: содержимое dist кладёт Makefile перед go build (сборка web).
# В git хранится только .gitkeep — go:embed требует непустую директорию для компиляции
# чистого чекаута.
backend/internal/web/dist/*
!backend/internal/web/dist/.gitkeep

# Mobile (Gradle).
mobile/.gradle/
mobile/build/
mobile/**/build/
mobile/local.properties

# IDE / OS.
.DS_Store
.idea/
.claude/
backend/workspace/
